{
  "name": "rasoi-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor shell for Rasoi (loads production web app)",
  "scripts": {
    "cap:sync": "cap sync",
    "cap:sync:android": "cap sync android",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "build:android": "cd android && ./gradlew bundleRelease",
    "build:android:debug": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/ios": "^7.2.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.2.0",
    "typescript": "^5"
  },
  "capacitor": {
    "platforms": [
      "ios",
      "android"
    ]
  }
}
