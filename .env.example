# Copy this file to `.env.local` and fill in values. Never commit `.env.local`.
# https://platform.openai.com/api-keys

# Required for POST /api/recipe
OPENAI_API_KEY=

# Optional; must support json_schema response_format (e.g. gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# POST /api/recipe: max requests per client IP per rolling hour (0 = unlimited).
# Helps limit OpenAI spend from anonymous traffic before you add user authentication.
RECIPE_RATE_LIMIT_PER_HOUR=30
