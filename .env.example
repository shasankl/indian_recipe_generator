# Copy this file to `.env.local` and fill in values. Never commit `.env.local`.
# https://platform.openai.com/api-keys

# Required for POST /api/recipe
OPENAI_API_KEY=sk-your-key-here

# Optional; must support json_schema response_format (e.g. gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# POST /api/recipe: max requests per client IP per rolling hour (0 = unlimited).
RECIPE_RATE_LIMIT_PER_HOUR=30

# Public site URL for legal links (no trailing slash). Example: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=

# Support email shown on /support and /privacy (required for app store listings)
NEXT_PUBLIC_SUPPORT_EMAIL=you@example.com
